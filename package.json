{
  "name": "hydri",
  "productName": "Hydri",
  "version": "0.1.0",
  "description": "Hydri — Your Caring Health Companion. An intelligent desktop hydration companion.",
  "author": "Hydri",
  "main": "./out/main/main.js",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "generate-icons": "node scripts/generate-icons.js",
    "dist": "npm run build && electron-builder --win",
    "dist:portable": "npm run build && electron-packager . Hydri --platform=win32 --arch=x64 --icon=build/icon.ico --extra-resource=build/icon-square.png --out=release-portable --overwrite --ignore=\"^/(src|electron|tools|tests|\\.git|release|release-portable|scripts)($|/)\""
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "framer-motion": "^11.18.2",
    "gsap": "^3.12.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "recharts": "^2.15.0",
    "systeminformation": "^5.31.16"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-packager": "^17.1.2",
    "electron-vite": "^3.0.0",
    "jimp": "^1.6.1",
    "png-to-ico": "^2.1.8",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.7"
  },
  "build": {
    "appId": "com.hydri.app",
    "productName": "Hydri",
    "copyright": "Copyright © 2026 Hydri",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "build/icon-square.png",
        "to": "icon-square.png"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Hydri",
      "runAfterFinish": true,
      "license": "build/LICENSE.txt"
    },
    "publish": {
      "provider": "github",
      "owner": "SundarNTK",
      "repo": "Hydri"
    }
  }
}
